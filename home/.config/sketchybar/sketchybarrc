PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####
# https://felixkratz.github.io/SketchyBar/config/bar
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker
sketchybar --bar position=top height=40 blur_radius=30 color=0x40000000 drawing=on

##### Changing Defaults #####
# https://felixkratz.github.io/SketchyBar/config/items
default=(
  padding_left=5
  padding_right=5
  icon.font="Maple Mono NF CN:Regular:14.0"
  label.font="Maple Mono NF CN:Regular:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

##### Adding Left Items #####
sketchybar --add item aerospace_mode left \
  --set aerospace_mode \
  icon="󱗃" \
  label.drawing=off \
  label.padding_left=0 \
  label.padding_right=0


# Aerospace workspaces
sketchybar --add event aerospace_workspace_change

MONITOR_COUNT=$(aerospace list-monitors | wc -l | tr -d ' ')

aerospace list-workspaces --all \
  --format '%{workspace}|%{monitor-id}|%{monitor-appkit-nsscreen-screens-id}' |
while IFS='|' read -r sid monitor_id sketchybar_display; do
    # Only show the workspaces you care about
    case "$sid" in
        1|2|3|4|A|B|C|D) ;;
        *) continue ;;
    esac

    # On a single monitor, show all workspaces on display 1 regardless of assignment
    if [ "$MONITOR_COUNT" -gt 1 ]; then
        display_val="$sketchybar_display"
    else
        display_val=1
    fi

    sketchybar --add item space.$sid left \
        --subscribe space.$sid aerospace_workspace_change \
        --set space.$sid \
        display="$display_val" \
        background.color=0x44ffffff \
        background.corner_radius=5 \
        background.height=20 \
        background.drawing=off \
        icon.drawing=off \
        label="$sid" \
        label.padding_left=8 \
        label.padding_right=8 \
        padding_left=2 \
        padding_right=2 \
        click_script="aerospace focus-monitor $monitor_id; aerospace workspace $sid" \
        script="$CONFIG_DIR/plugins/aerospace.sh $sid"
done

##### Adding Right Items #####
sketchybar --add item clock right \
           --set clock update_freq=10 icon=  script="$PLUGIN_DIR/clock.sh" \
           --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change \
           --add item calendar right \
           --set calendar update_freq=60 icon= script="$PLUGIN_DIR/calendar.sh"

##### Reload on monitor connect/disconnect #####
sketchybar --add item display_watcher q \
  --set display_watcher drawing=off update_freq=5 \
  --subscribe display_watcher display_added display_removed \
  --set display_watcher script="$PLUGIN_DIR/display_change.sh"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
